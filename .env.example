# ============================================
# Environment Configuration
# ============================================
#
# This file is a template for setting up your environment variables.
#
# SETUP INSTRUCTIONS:
#
# 1. FOR LOCAL DEVELOPMENT:
#    - Copy this file to `.env` (not tracked by git)
#    - Fill in your actual Supabase credentials
#    - Run `npm run dev`
#
# 2. FOR GITHUB PAGES DEPLOYMENT:
#    - Add these variables to GitHub Repository Secrets
#    - GitHub Actions will automatically use them during deployment
#    - Go to: Settings → Secrets and variables → Actions → New repository secret
#
# 3. REQUIRED VARIABLES:
#    - VITE_SUPABASE_URL (Supabase project URL)
#    - VITE_SUPABASE_PUBLISHABLE_KEY (Supabase anon/public key)
#    - VITE_SUPABASE_PROJECT_ID (Supabase project ID)
#
# 4. OPTIONAL VARIABLES:
#    - VITE_BASE_URL (Default: "/uri-finance/" for GitHub Pages)
#    - VITE_SYSTEM_ADMIN_EMAILS (Default: empty)
#
# ============================================

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard/project/your-project/settings/api
# 2. Copy the Project URL
# 3. Copy the anon/public key (labeled as "anon public")
# 4. Get the Project ID from the URL or dashboard

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id-here

# ============================================
# GitHub Pages Configuration
# ============================================
#
# IMPORTANT: This affects how assets and routes are loaded
#
# For GitHub Pages (username.github.io/repository-name):
#   VITE_BASE_URL=/repository-name/
#
# For custom domain:
#   VITE_BASE_URL=/
#
# Current setting for this repository (uri-finance):
#   VITE_BASE_URL=/uri-finance/
#
# NOTE: If you change VITE_BASE_URL, you must also:
#   1. Update BrowserRouter basename in src/App.tsx
#   2. Rebuild and redeploy

VITE_BASE_URL=/uri-finance/

# ============================================
# Landing Page Configuration (OPTIONAL)
# ============================================
#
# Customize the title and subtitle on the login/landing page.
# These will override the default "FinTrack" title.
#
# VITE_APP_AUTH_TITLE: Main title (e.g., MyFinance)
# VITE_APP_AUTH_SUBTITLE: Subtitle description
# VITE_APP_AUTH_TITLE_KO: Main title for Korean language
# VITE_APP_AUTH_SUBTITLE_KO: Subtitle for Korean language

VITE_APP_AUTH_TITLE=
VITE_APP_AUTH_SUBTITLE=
VITE_APP_AUTH_TITLE_KO=
VITE_APP_AUTH_SUBTITLE_KO=

# ============================================
# System Admin Emails (OPTIONAL)
# ============================================
#
# Comma-separated list of email addresses that have system admin access
# These users can access /global-admin route regardless of project membership
#
# Example: user1@example.com,user2@example.com
#
# Leave empty to disable global admin feature

VITE_SYSTEM_ADMIN_EMAILS=
